{
  "name": "Leanote-Desktop",
  "version": "1.0.0",
  "description": "Leanote Desktop - Not Just A Notepad",
  "author": "Leanote <leanote@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu --in-process-gpu",
    "start:dev": "electron . --devtools --no-sandbox --disable-gpu --in-process-gpu",
    "build:less": "bash build.sh less-only",
    "build:icons": "bash build.sh icons",
    "build:linux": "bash build.sh linux",
    "build:win": "bash build.sh win",
    "build:android": "bash build.sh android",
    "build:ios": "bash build.sh ios"
  },
  "dependencies": {
    "@electron/remote": "^2.0.10",
    "adm-zip": ">=0.4.11",
    "async": "0.9.0",
    "highlight.js": "^11.11.1",
    "iconv-lite": "0.4.15",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mkdirp": "0.3.5",
    "nedb": "1.1.1",
    "needle": "git://github.com/leanote/needle.git",
    "node-getmac": "1.0.3",
    "twemoji": "^14.0.2",
    "validator": ">=3.22.1",
    "xml2js": "0.4.6"
  },
  "devDependencies": {
    "electron": "^20.3.12",
    "electron-builder": "^26.8.1",
    "less": "^4.6.4"
  }
}
